from sklearn.model_selection import train_test_split
from sklearn.linear_model import LinearRegression


X = df[[
    "Price",
    "Calories",
    "Protein",
    "Fat",
    "Carbs",
    "Health_score"
]]


y = df["Rating"]


items = df["Item"]


X_train, X_test, y_train, y_test, item_train, item_test = train_test_split(
    X, y, items, test_size=0.2, random_state=42
)


model = LinearRegression()
model.fit(X_train, y_train)


predictions = model.predict(X_test)


X_test["Predicted_Rating"] = predictions


X_test["Item"] = item_test.values


X_test["Actual_Rating"] = y_test.values


X_test.to_csv("ml_predictions.csv", index=False)
